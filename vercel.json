{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/refresh-prices",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/refresh-sde",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron/refresh-gsc",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/sync-sweeper",
      "schedule": "*/15 * * * *"
    }
  ]
}
