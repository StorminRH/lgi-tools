{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "**": false,
      "*": false,
      "*/*": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/drain-esi-refresh-jobs",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/refresh-affiliations",
      "schedule": "20 11 * * *"
    },
    {
      "path": "/api/cron/refresh-prices",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/refresh-industry-indices",
      "schedule": "40 11 * * *"
    },
    {
      "path": "/api/cron/refresh-sde",
      "schedule": "50 11 * * *"
    },
    {
      "path": "/api/cron/refresh-gsc",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/sync-sweeper",
      "schedule": "*/15 * * * *"
    }
  ]
}
