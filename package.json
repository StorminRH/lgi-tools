{
  "name": "lgi-tools",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Stormin (Lo-Gang Industries)",
  "homepage": "https://github.com/StorminRH/lgi-tools#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/StorminRH/lgi-tools.git"
  },
  "bugs": {
    "url": "https://github.com/StorminRH/lgi-tools/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "tsx src/db/migrate.ts && tsx src/db/ingest-sde-if-empty.ts && next build && node scripts/assert-route-classification.mjs",
    "start": "next start",
    "assert:routes": "node scripts/assert-route-classification.mjs",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "DOTENV_PATH=.env.production.local tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:ingest:sde": "tsx src/db/ingest-sde.ts",
    "db:ingest:sde:prod": "DOTENV_PATH=.env.production.local tsx src/db/ingest-sde.ts",
    "db:refresh-prices": "tsx src/db/refresh-prices.ts",
    "db:refresh-prices:prod": "DOTENV_PATH=.env.production.local tsx src/db/refresh-prices.ts",
    "db:refresh-sde": "tsx src/db/refresh-sde.ts",
    "db:refresh-sde:prod": "DOTENV_PATH=.env.production.local tsx src/db/refresh-sde.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/speed-insights": "^2.0.0",
    "csv-parse": "^6.2.1",
    "drizzle-orm": "^0.45.2",
    "fuzzysort": "^3.1.0",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "unbzip2-stream": "^1.4.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/unbzip2-stream": "^1.4.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "knip": "^6.14.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild": ">=0.25.0",
      "postcss": ">=8.5.10"
    }
  }
}
