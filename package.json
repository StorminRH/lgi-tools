{
  "name": "lgi-tools",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "tsx src/db/migrate.ts && tsx src/db/ingest-sde-if-empty.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "DOTENV_PATH=.env.production.local tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:reseed-from-sheet": "tsx src/db/reseed-from-sheet.ts",
    "db:ingest:sde": "tsx src/db/ingest-sde.ts",
    "db:ingest:sde:prod": "DOTENV_PATH=.env.production.local tsx src/db/ingest-sde.ts",
    "db:refresh-prices": "tsx src/db/refresh-prices.ts",
    "db:refresh-prices:prod": "DOTENV_PATH=.env.production.local tsx src/db/refresh-prices.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip"
  },
  "dependencies": {
    "csv-parse": "^6.2.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "unbzip2-stream": "^1.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/unbzip2-stream": "^1.4.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "knip": "^6.14.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
