{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",

  "ignoreExportsUsedInFile": true,

  "entry": [
    "src/scripts/migrate.ts",
    "src/scripts/backfill-users-if-empty.ts",
    "src/scripts/ingest-sde-if-empty.ts",
    "src/scripts/ingest-sde.ts",
    "src/scripts/refresh-prices.ts",
    "src/scripts/refresh-sde.ts",
    "scripts/validate-resolver-output.ts",
    "scripts/assert-route-classification.mjs",
    "scripts/ux-capture.mjs",
    "drizzle.config.ts",
    "neon.ts"
  ],

  "ignorePatterns": [
    "convex/_generated/**",
    ".next/**",
    "out/**",
    "build/**",
    "**/*.d.ts",
    "next-env.d.ts",
    "**/*.generated.ts",
    "drizzle/**",
    "docs/**",
    "convex/**/*.test.ts"
  ],

  "ignoreDependencies": ["convex-test", "@edge-runtime/vm", "playwright"],

  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "off",
    "unused-dependencies": "error",
    "unlisted-dependencies": "error",
    "unused-enum-members": "warn",
    "unused-class-members": "warn",
    "unresolved-imports": "warn",
    "duplicate-exports": "warn",
    "circular-dependencies": "error",
    "re-export-cycle": "error",
    "boundary-violation": "error",
    "coverage-gaps": "off",
    "stale-suppressions": "warn",
    "feature-flags": "off"
  },

  "health": {
    "maxCyclomatic": 20,
    "maxCognitive": 15,
    "maxCrap": 30.0,
    "thresholdOverrides": []
  },

  "duplicates": {
    "mode": "mild",
    "minTokens": 50,
    "minLines": 5,
    "minOccurrences": 2,
    "threshold": 0,
    "ignoreDefaults": true,
    "ignore": [
      "**/*.test.ts",
      "**/*.test.tsx",
      "convex/_generated/**",
      "drizzle/**"
    ]
  },

  "boundaries": {
    "zones": [
      { "name": "ui", "patterns": ["src/components/ui/**"] },
      { "name": "platform/auth", "patterns": ["src/platform/auth/**"] },
      { "name": "platform/owner-sync", "patterns": ["src/platform/owner-sync/**"] },
      { "name": "platform/esi", "patterns": ["src/platform/esi/**"] },
      { "name": "platform/search", "patterns": ["src/platform/search/**"] },
      { "name": "platform/purge", "patterns": ["src/platform/purge/**"] },
      { "name": "platform/page-settings", "patterns": ["src/platform/page-settings/**"] },
      { "name": "composition", "patterns": ["src/composition/**"] },
      {
        "name": "components-composition",
        "patterns": ["src/components/composition/**"]
      },
      { "name": "features", "autoDiscover": ["src/features"] },
      { "name": "data", "autoDiscover": ["src/data"] },
      { "name": "lib", "patterns": ["src/lib/**"] },
      {
        "name": "components",
        "patterns": ["src/components/*.tsx", "src/components/*.ts", "src/components/telemetry/**"]
      },
      { "name": "api", "patterns": ["src/app/api/**"] },
      { "name": "app", "patterns": ["src/app/**"] },
      { "name": "scripts", "patterns": ["src/scripts/**"] },
      { "name": "transport", "patterns": ["src/transport/**"] },
      { "name": "db", "patterns": ["src/db/**"] },
      { "name": "config", "patterns": ["src/config/**"] },
      { "name": "esi-datasets", "patterns": ["src/esi-datasets/**"] },
      { "name": "convex", "patterns": ["convex/**"] },
      { "name": "runtime", "patterns": ["src/proxy*.ts", "src/instrumentation*.ts"] }
    ],
    "rules": [
      {
        "from": "app",
        "allow": [
          "components-composition",
          "composition",
          "components",
          "ui",
          "features",
          "platform/auth",
          "platform/esi",
          "platform/page-settings",
          "data",
          "transport",
          "lib",
          "config"
        ]
      },
      {
        "from": "api",
        "allow": [
          "transport",
          "composition",
          "features",
          "platform/auth",
          "platform/esi",
          "data",
          "db",
          "lib",
          "config"
        ]
      },
      {
        "from": "scripts",
        "allow": ["composition", "platform/auth", "data", "db", "lib"]
      },
      {
        "from": "runtime",
        "allow": ["transport", "features", "data", "lib", "config"]
      },
      {
        "from": "composition",
        "allow": [
          "features",
          "platform/auth",
          "platform/owner-sync",
          "platform/esi",
          "platform/search",
          "platform/purge",
          "platform/page-settings",
          "data",
          "transport",
          "db",
          "lib",
          "config"
        ]
      },
      {
        "from": "components-composition",
        "allow": [
          "composition",
          "components",
          "ui",
          "features",
          "platform/auth",
          "platform/search",
          "platform/page-settings",
          "data",
          "transport",
          "lib",
          "config"
        ]
      },
      {
        "from": "features",
        "allow": [
          "platform/auth",
          "platform/owner-sync",
          "platform/search",
          "platform/purge",
          "platform/page-settings",
          "data",
          "transport",
          "db",
          "lib",
          "config",
          "ui",
          "components"
        ]
      },
      {
        "from": "components",
        "allow": [
          "ui",
          "platform/auth",
          "platform/search",
          "platform/page-settings",
          "data",
          "transport",
          "lib"
        ]
      },
      {
        "from": "data",
        "allow": [
          "data/eve-data",
          "platform/esi",
          "platform/owner-sync",
          "platform/search",
          "platform/purge",
          "transport",
          "db",
          "lib",
          "config"
        ]
      },
      {
        "from": "platform/auth",
        "allow": [
          "platform/esi",
          "platform/purge",
          "data",
          "transport",
          "db",
          "lib",
          "config"
        ]
      },
      { "from": "platform/owner-sync", "allow": ["platform/esi"] },
      { "from": "platform/esi", "allow": ["lib", "config"] },
      { "from": "platform/search", "allow": [] },
      { "from": "platform/purge", "allow": [] },
      { "from": "platform/page-settings", "allow": ["lib"] },
      { "from": "transport", "allow": ["lib"] },
      { "from": "db", "allow": ["lib", "config"] },
      { "from": "lib", "allow": ["config"] },
      { "from": "ui", "allow": [] },
      { "from": "config", "allow": [] },
      {
        "from": "convex",
        "allow": ["platform/esi", "platform/auth", "data", "lib"]
      },
      {
        "from": "esi-datasets",
        "allow": [
          "composition",
          "db",
          "data",
          "features",
          "platform/auth",
          "platform/purge",
          "lib"
        ]
      }
    ],
    "coverage": {
      "requireAllFiles": true,
      "allowUnmatched": [
        "scripts/**",
        "neon.ts",
        "next.config.ts",
        "drizzle.config.ts",
        "vitest.config.ts",
        "eslint.config.mjs"
      ]
    }
  },

  "audit": {
    "gate": "new-only",
    "dupesBaseline": "fallow-baselines/dupes.json"
  }
}
