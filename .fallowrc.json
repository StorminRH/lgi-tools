{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",

  "ignoreExportsUsedInFile": true,

  "entry": [
    "src/db/migrate.ts",
    "src/db/backfill-users-if-empty.ts",
    "src/db/ingest-sde-if-empty.ts",
    "src/db/ingest-sde.ts",
    "src/db/refresh-prices.ts",
    "src/db/refresh-sde.ts",
    "scripts/validate-resolver-output.ts",
    "scripts/assert-route-classification.mjs",
    "scripts/ux-capture.mjs",
    "drizzle.config.ts",
    "neon.ts"
  ],

  "ignorePatterns": [
    "convex/_generated/**",
    ".next/**",
    "out/**",
    "build/**",
    "**/*.d.ts",
    "next-env.d.ts",
    "**/*.generated.ts",
    "drizzle/**",
    "docs/**",
    "convex/**/*.test.ts"
  ],

  "ignoreDependencies": ["convex-test", "@edge-runtime/vm", "playwright"],

  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "off",
    "unused-dependencies": "error",
    "unlisted-dependencies": "error",
    "unused-enum-members": "warn",
    "unused-class-members": "warn",
    "unresolved-imports": "warn",
    "duplicate-exports": "warn",
    "circular-dependencies": "warn",
    "re-export-cycle": "warn",
    "boundary-violation": "error",
    "coverage-gaps": "off",
    "stale-suppressions": "warn",
    "feature-flags": "off"
  },

  "health": {
    "maxCyclomatic": 20,
    "maxCognitive": 15,
    "maxCrap": 30.0,
    "thresholdOverrides": []
  },

  "duplicates": {
    "mode": "mild",
    "minTokens": 50,
    "minLines": 5,
    "minOccurrences": 2,
    "threshold": 0,
    "ignoreDefaults": true,
    "ignore": [
      "**/*.test.ts",
      "**/*.test.tsx",
      "convex/_generated/**",
      "drizzle/**"
    ]
  },

  "boundaries": {
    "zones": [
      {
        "// note": "First-match-wins: auth-surface is listed BEFORE the features autoDiscover zone so these 3 files classify here, not into features/auth. Verified via `fallow list --boundaries` (auth-surface=3 files, classified ahead of the larger features/auth zone). Fallow is the sole mechanical boundary owner; docs/architecture-boundaries.md carries the single prose map.",
        "name": "auth-surface",
        "patterns": [
          "src/features/auth/types.ts",
          "src/features/auth/schema.ts",
          "src/features/auth/api-contract.ts"
        ]
      },
      { "name": "ui", "patterns": ["src/components/ui/**"] },
      { "name": "features", "autoDiscover": ["src/features"] },
      { "name": "data", "autoDiscover": ["src/data"] },
      { "name": "lib", "patterns": ["src/lib/**"] },
      {
        "name": "shared",
        "patterns": ["src/components/*.tsx", "src/components/*.ts", "src/components/telemetry/**"]
      },
      { "name": "app", "patterns": ["src/app/**"] },
      { "name": "db", "patterns": ["src/db/**"] },
      { "name": "config", "patterns": ["src/config/**"] },
      { "name": "purge", "patterns": ["src/purge/**"] },
      { "name": "search", "patterns": ["src/search/**"] },
      { "name": "page-settings", "patterns": ["src/page-settings/**"] },
      { "name": "esi-datasets", "patterns": ["src/esi-datasets/**"] },
      { "name": "convex", "patterns": ["convex/**"] },
      { "name": "runtime", "patterns": ["src/proxy*.ts", "src/instrumentation*.ts"] }
    ],
    "rules": [
      { "from": "auth-surface", "allow": ["auth-surface", "lib"] },
      {
        "from": "features",
        "allow": [
          "ui",
          "data",
          "lib",
          "shared",
          "auth-surface",
          "db",
          "config",
          "purge",
          "search",
          "page-settings"
        ]
      },
      { "from": "data", "allow": ["lib", "auth-surface", "db", "config", "search", "purge"] },
      {
        "from": "data/npc-stats",
        "allow": [
          "lib",
          "auth-surface",
          "data/eve-data",
          "db",
          "config",
          "search",
          "purge"
        ]
      },
      { "from": "lib", "allow": ["lib", "config"] },
      { "from": "ui", "allow": ["lib"] },
      {
        "from": "shared",
        "allow": [
          "ui",
          "lib",
          "data",
          "features",
          "auth-surface",
          "config",
          "page-settings",
          "search"
        ]
      },
      {
        "from": "app",
        "allow": [
          "features",
          "data",
          "ui",
          "shared",
          "db",
          "config",
          "page-settings",
          "auth-surface",
          "lib"
        ]
      },
      {
        "from": "db",
        "allow": [
          "data",
          "features",
          "config",
          "auth-surface",
          "purge",
          "esi-datasets",
          "lib"
        ]
      },
      { "from": "config", "allow": ["lib"] },
      { "from": "purge", "allow": ["data", "features", "db", "lib"] },
      { "from": "search", "allow": ["data", "features", "auth-surface", "lib"] },
      { "from": "page-settings", "allow": ["features", "lib"] },
      { "from": "esi-datasets", "allow": ["data", "db", "features", "lib"] },
      {
        "from": "convex",
        "allow": ["data", "auth-surface", "lib", "features/online-status"],
        "// note": "Narrow exception: online-status Convex sync reuses the feature's runtime-light pure ESI-projection + eligibility helpers by design (documented at the import sites). Precedent: data/npc-stats -> data/eve-data. Relocation to a data leaf is future work."
      },
      { "from": "runtime", "allow": ["config", "data", "features", "lib"] }
    ],
    "coverage": {
      "requireAllFiles": true,
      "allowUnmatched": [
        "scripts/**",
        "neon.ts",
        "next.config.ts",
        "drizzle.config.ts",
        "vitest.config.ts",
        "eslint.config.mjs"
      ]
    }
  },

  "audit": {
    "gate": "new-only",
    "dupesBaseline": "fallow-baselines/dupes.json"
  }
}
