{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",

  "ignoreExportsUsedInFile": true,

  "entry": [
    "src/db/migrate.ts",
    "src/db/backfill-users-if-empty.ts",
    "src/db/ingest-sde-if-empty.ts",
    "src/db/ingest-sde.ts",
    "src/db/refresh-prices.ts",
    "src/db/refresh-sde.ts",
    "scripts/validate-resolver-output.ts",
    "scripts/assert-route-classification.mjs",
    "scripts/ux-capture.mjs",
    "drizzle.config.ts",
    "neon.ts"
  ],

  "ignorePatterns": [
    "convex/_generated/**",
    ".next/**",
    "out/**",
    "build/**",
    "**/*.d.ts",
    "next-env.d.ts",
    "**/*.generated.ts",
    "drizzle/**",
    "docs/**",
    "convex/**/*.test.ts"
  ],

  "ignoreDependencies": ["convex-test", "@edge-runtime/vm", "playwright"],

  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "off",
    "unused-dependencies": "error",
    "unlisted-dependencies": "error",
    "unused-enum-members": "warn",
    "unused-class-members": "warn",
    "unresolved-imports": "warn",
    "duplicate-exports": "warn",
    "circular-dependencies": "warn",
    "re-export-cycle": "warn",
    "boundary-violation": "error",
    "coverage-gaps": "off",
    "stale-suppressions": "warn",
    "feature-flags": "off"
  },

  "health": {
    "maxCyclomatic": 20,
    "maxCognitive": 15,
    "maxCrap": 30.0,
    "thresholdOverrides": []
  },

  "duplicates": {
    "mode": "mild",
    "minTokens": 50,
    "minLines": 5,
    "minOccurrences": 2,
    "threshold": 0,
    "ignoreDefaults": true,
    "ignore": [
      "**/*.test.ts",
      "**/*.test.tsx",
      "convex/_generated/**",
      "drizzle/**"
    ]
  },

  "boundaries": {
    "zones": [
      {
        "// note": "Interim first-match rule retained until the final layer-map tightening retires auth-surface.",
        "name": "auth-surface",
        "patterns": [
          "src/platform/auth/types.ts",
          "src/platform/auth/api-contract.ts"
        ]
      },
      { "name": "ui", "patterns": ["src/components/ui/**"] },
      { "name": "platform/auth", "patterns": ["src/platform/auth/**"] },
      { "name": "platform/owner-sync", "patterns": ["src/platform/owner-sync/**"] },
      { "name": "platform/esi", "patterns": ["src/platform/esi/**"] },
      { "name": "platform/search", "patterns": ["src/platform/search/**"] },
      { "name": "platform/purge", "patterns": ["src/platform/purge/**"] },
      { "name": "platform/page-settings", "patterns": ["src/platform/page-settings/**"] },
      { "name": "composition", "patterns": ["src/composition/**"] },
      { "name": "features", "autoDiscover": ["src/features"] },
      { "name": "data", "autoDiscover": ["src/data"] },
      { "name": "lib", "patterns": ["src/lib/**"] },
      {
        "name": "shared",
        "patterns": ["src/components/*.tsx", "src/components/*.ts", "src/components/telemetry/**"]
      },
      { "name": "api", "patterns": ["src/app/api/**"] },
      { "name": "app", "patterns": ["src/app/**"] },
      { "name": "transport", "patterns": ["src/transport/**"] },
      { "name": "db", "patterns": ["src/db/**"] },
      { "name": "config", "patterns": ["src/config/**"] },
      { "name": "esi-datasets", "patterns": ["src/esi-datasets/**"] },
      { "name": "convex", "patterns": ["convex/**"] },
      { "name": "runtime", "patterns": ["src/proxy*.ts", "src/instrumentation*.ts"] }
    ],
    "rules": [
      {
        "from": "auth-surface",
        "allow": ["auth-surface", "lib", "config", "transport"]
      },
      {
        "from": "platform/auth",
        "allow": [
          "ui",
          "data",
          "lib",
          "shared",
          "auth-surface",
          "db",
          "config",
          "platform/esi",
          "platform/search",
          "platform/purge",
          "platform/page-settings",
          "transport"
        ]
      },
      { "from": "platform/owner-sync", "allow": ["platform/esi", "lib"] },
      { "from": "platform/esi", "allow": ["lib", "config"] },
      { "from": "platform/search", "allow": ["lib"] },
      { "from": "platform/purge", "allow": ["lib"] },
      { "from": "platform/page-settings", "allow": ["lib"] },
      {
        "from": "composition",
        "allow": [
          "platform/auth",
          "platform/owner-sync",
          "platform/esi",
          "platform/search",
          "platform/purge",
          "platform/page-settings",
          "transport",
          "auth-surface",
          "features",
          "data",
          "db",
          "lib",
          "config"
        ]
      },
      {
        "from": "features",
        "allow": [
          "ui",
          "data",
          "lib",
          "shared",
          "auth-surface",
          "db",
          "config",
          "platform/auth",
          "platform/owner-sync",
          "platform/esi",
          "platform/search",
          "platform/purge",
          "platform/page-settings",
          "transport"
        ]
      },
      {
        "from": "data",
        "allow": [
          "lib",
          "auth-surface",
          "db",
          "config",
          "platform/auth",
          "platform/owner-sync",
          "platform/esi",
          "platform/search",
          "platform/purge",
          "transport"
        ]
      },
      {
        "from": "data/npc-stats",
        "allow": [
          "lib",
          "auth-surface",
          "data/eve-data",
          "db",
          "config",
          "platform/auth",
          "platform/owner-sync",
          "platform/esi",
          "platform/search",
          "platform/purge",
          "transport"
        ]
      },
      { "from": "lib", "allow": ["lib", "config"] },
      { "from": "ui", "allow": ["lib"] },
      {
        "from": "shared",
        "allow": [
          "ui",
          "lib",
          "data",
          "features",
          "auth-surface",
          "config",
          "platform/auth",
          "composition",
          "platform/owner-sync",
          "platform/esi",
          "platform/search",
          "platform/page-settings",
          "transport"
        ]
      },
      {
        "from": "api",
        "allow": [
          "transport",
          "composition",
          "features",
          "platform/auth",
          "platform/owner-sync",
          "platform/esi",
          "data",
          "db",
          "lib",
          "config",
          "auth-surface",
          "platform/search",
          "platform/purge",
          "platform/page-settings"
        ]
      },
      {
        "from": "app",
        "allow": [
          "features",
          "data",
          "ui",
          "shared",
          "db",
          "config",
          "auth-surface",
          "lib",
          "platform/auth",
          "composition",
          "platform/owner-sync",
          "platform/esi",
          "platform/search",
          "platform/page-settings",
          "transport"
        ]
      },
      {
        "from": "db",
        "allow": [
          "data",
          "features",
          "config",
          "auth-surface",
          "esi-datasets",
          "lib",
          "platform/auth",
          "composition",
          "platform/owner-sync",
          "platform/esi",
          "platform/purge",
          "transport"
        ]
      },
      { "from": "transport", "allow": ["lib", "config"] },
      { "from": "config", "allow": ["lib"] },
      {
        "from": "esi-datasets",
        "allow": [
          "data",
          "db",
          "features",
          "lib",
          "platform/auth",
          "platform/owner-sync",
          "platform/esi",
          "composition"
        ]
      },
      {
        "from": "convex",
        "allow": [
          "data",
          "auth-surface",
          "lib",
          "features/online-status",
          "platform/auth",
          "platform/esi"
        ],
        "// note": "Narrow exception: online-status Convex sync reuses the feature's runtime-light pure ESI-projection + eligibility helpers by design (documented at the import sites). Precedent: data/npc-stats -> data/eve-data. Relocation to a data leaf is future work."
      },
      { "from": "runtime", "allow": ["config", "data", "features", "lib", "transport"] }
    ],
    "coverage": {
      "requireAllFiles": true,
      "allowUnmatched": [
        "scripts/**",
        "neon.ts",
        "next.config.ts",
        "drizzle.config.ts",
        "vitest.config.ts",
        "eslint.config.mjs"
      ]
    }
  },

  "audit": {
    "gate": "new-only",
    "dupesBaseline": "fallow-baselines/dupes.json"
  }
}
