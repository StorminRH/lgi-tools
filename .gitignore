# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# local agent state (never tracked)
.claude/settings.local.json
.claude/launch.json
.claude/worktrees/
.agent-local/tooling-parity-report.json
.agent-local/pr-*.md
.agent-local/pr-privacy-local-patterns.txt
docs/ux-check/captures/
docs/ux-check/profiles/
docs/margin-audit/
.codegraph/

# typescript
*.tsbuildinfo
next-env.d.ts

# local verification snapshots (wire-format diffs, not committed)
.verify-snapshots/

# fallow (codebase-intelligence eval). The regression-count floor lives embedded
# in .fallowrc.json (regression.baseline), so nothing under .fallow/ needs to be
# committed — ignore the whole local cache and the CI artifact dirs.
/.fallow/
/fallow-out/
/fallow-backstop/

# python bytecode (agent-local tooling + tests)
__pycache__/
*.py[cod]
