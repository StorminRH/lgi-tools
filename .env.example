# LGI.tools — local environment variables.
#
# Copy this file to .env.local and fill in the values below. Anything ending
# in _SECRET, _KEY, or with a value here, MUST be unique per environment —
# never commit a real value to git.

# Local dev points at the Postgres container started by docker-compose.yml.
# In production, Vercel injects DATABASE_URL from the Neon integration —
# this is the pooled (`-pooler`) endpoint, used by all request-path queries.
DATABASE_URL=postgres://lgi:lgi@localhost:5433/lgi_tools

# Direct (unpooled) Neon endpoint — provisioned by the Neon integration in
# production/preview. Session-scoped advisory locks (price + SDE refresh
# jobs) hold only on a stable backend, which the pooler doesn't provide, so
# the lock holders connect here. Optional locally: when unset it falls back
# to DATABASE_URL, which on Docker has no pooler. Required in prod — the lock
# holders fail closed if it's missing and DATABASE_URL is the pooled endpoint.
DATABASE_URL_UNPOOLED=

# Schema-owner credential used ONLY by migrations (src/db/migrate.ts, which runs
# inside the production build). Empty ≡ unset: migrations fall back to
# DATABASE_URL, so single-role and local/dev environments are unaffected. Set
# this only after the LGI-08 role split (docs/security/db-privilege-runbook.md):
# point DATABASE_URL / DATABASE_URL_UNPOOLED at the least-privilege lgi_runtime
# login role and DATABASE_MIGRATION_URL at the owner role that runs DDL.
DATABASE_MIGRATION_URL=

# Local dev only — leave UNSET in production/preview. The request-path DB client
# defaults to the neon-http driver, which speaks HTTP to a Neon SQL endpoint and
# CANNOT reach a plain local Postgres (every page would 500 with "fetch failed").
# Set this to `postgres-js` to build the local request client over TCP instead,
# so `pnpm dev` works against the docker-compose Postgres. Vercel never sets it.
LOCAL_DB_DRIVER=postgres-js

# Optional alternate dotenv file read by database/config scripts. Leave blank
# for the normal .env.local lookup; production scripts set it explicitly.
# DOTENV_PATH=

# EVE Online SSO — register a dev app at https://developers.eveonline.com/applications
# Login runs through Better Auth's Generic OAuth plugin, so the redirect URI you
# register in the EVE app is now the plugin's callback path:
#   <BETTER_AUTH_URL>/api/auth/oauth2/callback/eve
# (locally: http://localhost:3000/api/auth/oauth2/callback/eve). EVE matches
# redirect URIs exactly — register one per origin you sign in against.
# Enable the scopes in the authoritative EVE_SCOPES array:
# src/platform/auth/eve-sso.ts
EVE_CLIENT_ID=
EVE_CLIENT_SECRET=

# Better Auth — the auth layer that owns sessions and the EVE OAuth flow.
# BETTER_AUTH_SECRET signs sessions/cookies; reuse the same 32-byte value as
# SESSION_SECRET (the auth layer falls back to SESSION_SECRET if this is unset).
# BETTER_AUTH_URL is the canonical origin the callback URL is derived from —
# set it per environment (locally http://localhost:3000). It is ALSO the issuer
# (`iss`) of the Convex-facing JWT minted at <BETTER_AUTH_URL>/api/auth/token
# (audience `aud` = "convex"); record both for Convex's auth.config.ts (3.4.3).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# 32-byte random key. Originally the session-cookie encryption key; still the
# fallback source for BETTER_AUTH_SECRET. Generate via: openssl rand -base64 32
SESSION_SECRET=

# Dedicated key that encrypts each character's EVE access/refresh tokens at rest
# in Neon (AES-256-GCM). Kept SEPARATE from BETTER_AUTH_SECRET so token custody
# has its own blast radius. Must decode to exactly 32 bytes — generate via:
# openssl rand -base64 32. Required wherever auth runs; rotating it makes every
# stored token undecryptable, so every character must reconnect.
EVE_TOKEN_ENCRYPTION_KEY=

# Dedicated key for permission-sensitive raw ESI snapshots in Neon. Uses the
# same AES-256-GCM envelope as token custody but a separate key and blast radius.
# Must decode to exactly 32 bytes — generate via: openssl rand -base64 32.
ESI_SNAPSHOT_ENCRYPTION_KEY=

# EVE character ID granted built-in superadmin powers. Bootstrap-only —
# cannot be revoked without rotating this env var. Leave blank for a
# vanilla dev session with no admin user.
SUPERADMIN_CHARACTER_ID=

# Discord webhook URL the /api/feedback route forwards user feedback to.
# Create one under Server Settings → Integrations → Webhooks in Discord.
# Leave blank to disable feedback forwarding.
DISCORD_WEBHOOK_URL=

# Separate Discord webhook for ops/error alerts — a distinct channel from the
# user feedback above. Leave blank to disable ops alerts.
DISCORD_ALERT_WEBHOOK_URL=

# Bearer token the Vercel cron uses to authenticate /api/cron/refresh-prices,
# /api/cron/refresh-sde, and /api/cron/refresh-gsc.
# Generate via: openssl rand -hex 32
# Required in production; optional locally (the cron endpoint won't be hit).
CRON_SECRET=

# Shared bearer the Convex backend sends to POST /api/internal/eve-token to vend
# a fresh short-lived EVE access token for a character. DISTINCT from CRON_SECRET.
# Set the SAME value in BOTH Convex's env (the sender) and Vercel's env (this
# verifier). Generate via: openssl rand -hex 32. Required in production; optional
# locally (only hit when exercising the Convex contract).
CONVEX_SERVICE_SECRET=

# Google Search Console (server-only; BACKEND SYNC ONLY — no Google script on
# any page, no cookies, no user tracking). The daily cron (/api/cron/refresh-gsc)
# pulls search-analytics + sitemap + a bounded URL-inspection snapshot into our
# own database; the admin dashboard reads only the stored copy. Reuses
# CRON_SECRET for the cron's bearer auth.
#
# GSC_SERVICE_ACCOUNT_JSON: the full service-account key JSON on ONE line
# (JSON.parse'd at runtime; the private_key's \n escapes survive and the JWT
# client accepts them). Setup: create a Google Cloud service account, enable the
# Search Console API, download the JSON key, then add its client_email as a USER
# (Restricted is enough — read-only) of the verified lgi.tools property in Search
# Console → Settings → Users and permissions. Blank = sync disabled (the cron
# no-ops and the dashboard hides the GSC cards). Never exposed to the browser.
# (If an env store mangles the one-line JSON, base64-encode it — the loader
# also accepts a base64 blob.)
GSC_SERVICE_ACCOUNT_JSON=
# The exact verified property string — must match Search Console character for
# character, or every API call 404s. URL-prefix property → https://lgi.tools/
# (keep the trailing slash); Domain property → sc-domain:lgi.tools.
GSC_SITE_URL=https://lgi.tools/

# Optional Search Console ownership token rendered into page metadata.
# GOOGLE_SITE_VERIFICATION=

# Convex (3.4.3) — the reactive data backend for live tracker state. The
# browser connects DIRECTLY to the Convex deployment over https + wss; the
# CSP connect-src is derived from this URL at build time (src/proxy.ts).
#
# NEXT_PUBLIC_CONVEX_URL + CONVEX_DEPLOYMENT are written into .env.local by
# `npx convex dev` (one-time: `npx convex login`, then it provisions your
# personal dev deployment). On Vercel NEITHER is a stored env var:
# `pnpm exec convex deploy` (the vercel-build script) injects the exact
# per-deployment URL into the build env — prod gets the prod backend, each
# preview branch gets a fresh isolated preview backend. Leave blank to run
# the site without Convex (the provider and smoke page degrade gracefully).
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
#
# Lives in CONVEX's deployment env (`npx convex env set …`), NOT here and NOT
# in Vercel:
#   AUTH_ISSUER_URL       = the minting env's BETTER_AUTH_URL (the JWT `iss`;
#                           local dev: http://localhost:3000)
#   AUTH_JWKS             = data:text/plain;charset=utf-8;base64,<base64 of
#                           <AUTH_ISSUER_URL>/api/auth/jwks> (static keypair,
#                           embedded to skip the remote fetch on validation)
#   CONVEX_SERVICE_SECRET = same value as Vercel's (prod only; authenticates
#                           internal character/token reads and Convex HTTP actions)
#   SITE_URL              = https://lgi.tools (base URL for Convex's internal
#                           character and token requests)
# A Convex push FAILS if auth.config.ts references an unset env var, so the
# project's default env vars (dashboard → project settings) carry neutralized
# placeholders for preview/dev backends: previews validate no real JWT and
# stay anonymous-only by design. No EVE client id/secret in Convex, ever —
# token custody and refresh stay on the Neon side.

# Upstash Redis (REST) — backs the per-IP rate limiter on /api/feedback
# and /api/market-prices/refresh. In production / preview these are
# provisioned automatically by the Vercel ↔ Upstash marketplace
# integration as KV_REST_API_URL / KV_REST_API_TOKEN (Vercel KV naming —
# same Upstash database underneath). The helper reads either pair, so a
# direct upstash.com signup using the UPSTASH_REDIS_REST_* names also
# works. Mirror production into .env.local by copying values from
# `vercel env pull`. Leave blank locally to bypass rate limiting in dev
# (the limiter logs a one-shot warn and returns ok).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Or, for a non-Vercel Upstash:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Local diagnostic override for rebuilding the resolved EVE data tree.
# Leave blank during normal development and in every deployed environment.
# LGI_FORCE_TREE_REBUILD=

# Development-only opt-in for rendering /sites from a small representative
# catalogue sample. Use `pnpm dev:sample`; never set this in deployed environments.
# LGI_SITES_SAMPLE=
