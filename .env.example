# Local dev points at the Postgres container started by docker-compose.yml.
# In production, Vercel injects DATABASE_URL from the Neon integration.
DATABASE_URL=postgres://lgi:lgi@localhost:5433/lgi_tools

# Published Google Sheet key (the long "2PACX-..." token from the /d/e/<KEY>/pubhtml URL).
# The Sheet is Grubu's wormhole site guide; tabs are fetched as CSV via
# https://docs.google.com/spreadsheets/d/e/<KEY>/pub?gid=<GID>&single=true&output=csv
SHEET_PUB_KEY=2PACX-1vSaCHnBRDw8Ki6nuamMzQv3InN978Zh7F6RcwlYdJHnlQkDrrdz5zrG3Of_8eoyxeqJimMHt9-7GjLn

# EVE Online SSO — https://developers.eveonline.com/applications
# Register a dev app, scope publicData, callback URL http://localhost:3000/api/auth/callback
EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
EVE_CALLBACK_URL=http://localhost:3000/api/auth/callback

# 32-byte random key, base64url-encoded. Used to A256GCM-encrypt the session cookie.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# EVE character ID with built-in superadmin powers. Bootstrap-only (can't be
# revoked without rotating this env var). Consumed by 2.8.2's admin gate.
SUPERADMIN_CHARACTER_ID=

# Discord webhook URL the /api/feedback route forwards user feedback to.
# Create one under Server Settings → Integrations → Webhooks in Discord.
# Consumed by 2.8.5's feedback modal.
DISCORD_WEBHOOK_URL=
